{
	"private": true,
	"type": "module",
	"imports": {
		"#*": "./*"
	},
	"scripts": {
		"build": "pnpm run \"/^build:.*/\"",
		"build:css": "tailwindcss --input ./app/app.css --output ./public/assets/app.css --minify",
		"dev": "pnpm run \"/^dev:.*/\"",
		"dev:browser": "esbuild app/assets/*.tsx --outbase=app/assets --outdir=public/assets --bundle --minify --splitting --format=esm --entry-names='[dir]/[name]' --chunk-names='chunks/[name]-[hash]' --sourcemap --watch",
		"dev:css": "node --run build:css -- --watch",
		"dev:server": "NODE_ENV=development tsx watch --env-file .env server.ts",
		"start": "tsx server.ts",
		"test": "NODE_ENV=test tsx --test",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@brielov/crypto": "npm:@jsr/brielov__crypto@0.2.0",
		"@mcansh/cld-apis-types": "0.0.0",
