{
	"private": true,
	"type": "module",
	"imports": {
		"#*": "./*"
	},
	"scripts": {
		"css": "tailwindcss --input ./app/app.css --output ./public/assets/app.css",
		"browser": "esbuild app/assets/**/*.tsx --outbase=app/assets --outdir=public/assets --bundle --splitting --format=esm --entry-names='[dir]/[name]' --chunk-names='chunks/[name]-[hash]'",
		"build": "pnpm run \"/^build:.*/\"",
		"build:css": "node --run css -- --minify",
		"build:browser": "node --run browser -- --minify",
		"dev": "pnpm run \"/^dev:.*/\"",
		"dev:browser": "node --run browser -- --sourcemap --watch",
		"dev:css": "node --run css -- --watch",
		"dev:server": "NODE_ENV=development tsx watch --env-file .env server.ts",
		"start": "tsx server.ts",
		"test": "NODE_ENV=test tsx --test",
		"typecheck": "tsgo --noEmit",
		"format": "oxfmt"
	},
	"dependencies": {
		"@brielov/crypto": "npm:@jsr/brielov__crypto@0.2.0",
		"@mcansh/cld-apis-types": "0.0.0",
		"@mcansh/cloudinary-build-url": "0.0.0",
		"@mcansh/http-helmet": "0.13.2",
		"@paralleldrive/cuid2": "3.0.4",
		"@remix-run/async-context-middleware": "0.1.0",
		"@remix-run/compression-middleware": "0.1.0",
		"@remix-run/cookie": "0.5.0",
		"@remix-run/dom": "0.0.0-experimental-remix-jam.6",
		"@remix-run/events": "0.0.0-experimental-remix-jam.5",
		"@remix-run/fetch-router": "0.14.0",
		"@remix-run/form-data-middleware": "0.1.1",
		"@remix-run/form-data-parser": "0.14.0",
		"@remix-run/headers": "0.18.0",
		"@remix-run/interaction": "0.3.0",
		"@remix-run/library": "0.0.0-experimental-remix-jam.6",
		"@remix-run/logger-middleware": "0.1.0",
		"@remix-run/method-override-middleware": "0.1.1",
		"@remix-run/mime": "0.2.0",
		"@remix-run/node-fetch-server": "0.13.0",
		"@remix-run/response": "0.2.1",
		"@remix-run/route-pattern": "0.16.0",
		"@remix-run/session": "0.4.1",
		"@remix-run/session-middleware": "0.1.1",
		"@remix-run/static-middleware": "0.4.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"decode-formdata": "0.9.0",
		"drizzle-cuid2": "2.2.0",
		"drizzle-orm": "1.0.0-beta.3-36e9b9e",
		"drizzle-zod": "1.0.0-beta.2-36e9b9e",
		"pg": "8.16.3",
		"tailwind-merge": "3.4.0",
		"zod": "4.2.1"
	},
	"devDependencies": {
		"@tailwindcss/cli": "4.1.18",
		"@tailwindcss/forms": "0.5.11",
		"@total-typescript/tsconfig": "1.0.4",
		"@tsconfig/vite-react": "7.0.2",
		"@types/node": "25.0.3",
		"@types/pg": "8.16.0",
		"@typescript/native-preview": "7.0.0-dev.20251219.1",
